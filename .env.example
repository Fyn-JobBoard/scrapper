# ==============================
# Configuration du scraper FYN
# ==============================

# URL de l'API NestJS (backend Fyn)
API_BASE_URL=http://localhost:3000

# Clé d'authentification vers l'API (à définir avec ton équipe)
API_SECRET_KEY=your_secret_key_here

# Délai entre les requêtes (en secondes) pour éviter le blocage
SCRAPER_DELAY=2

# Nombre maximum d'offres à scraper par session
MAX_OFFERS_PER_RUN=100

# Mode headless Playwright (true en prod, false pour déboguer)
PLAYWRIGHT_HEADLESS=true
